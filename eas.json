{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://flirtyfy.vercel.app",
        "EXPO_PUBLIC_OPENAI_MODEL": "google/gemini-2.0-flash-001",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://flirtyfy.vercel.app",
        "EXPO_PUBLIC_OPENAI_MODEL": "google/gemini-2.0-flash-001",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    }
  }
}