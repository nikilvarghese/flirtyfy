{
  "expo": {
    "name": "Flirtyfy",
    "slug": "flirtyfy",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "flirtyfy",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d0d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flirtyfy.app",
      "associatedDomains": [
        "applinks:REPLACE_WITH_YOUR_DOMAIN"
      ]
    },
    "android": {
      "package": "com.flirtyfy.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d0d"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "androidStatusBar": {
        "barStyle": "light-content",
        "backgroundColor": "#0d0d0d",
        "translucent": true
      },
      "predictiveBackGestureEnabled": false,
      "notification": {
        "icon": "./assets/notification-icon.png",
        "color": "#ff4f7b"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "flirtyfy"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0d0d0d",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      "expo-localization",
      "expo-font",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "your-org"
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "182b9087-dda0-4f68-9343-b416d0f116f2"
      }
    },
    "owner": "nikil.varghese"
  }
}
